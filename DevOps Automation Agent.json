    {
      "parameters": {
        "jsCode": "const jobs = $json.jobs || [];\n\nlet failedJob = null;\nlet failedStep = null;\n\nfor (const job of jobs) {\n  if (job.conclusion === 'failure') {\n    failedJob = job.name;\n    const step = (job.steps || []).find(s => s.conclusion === 'failure');\n    failedStep = step ? step.name : null;\n    break;\n  }\n}\n\nreturn [\n  {\n    json: {\n      ...$input.first().json,\n      failed_job: failedJob,\n      failed_step: failedStep\n    }\n  }\n];"
      },
