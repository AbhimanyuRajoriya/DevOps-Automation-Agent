    {
      "parameters": {
        "jsCode": "const raw = $json.output;\n\nif (!raw || typeof raw !== \"string\") {\n  throw new Error(\"AI output is empty or not a string\");\n}\n\nlet cleaned = raw.trim()\n  .replace(/^```json\\s*/i, \"\")\n  .replace(/^```\\s*/i, \"\")\n  .replace(/\\s*```$/, \"\")\n  .trim();\n\nlet parsed;\n\ntry {\n  parsed = JSON.parse(cleaned);\n} catch (error) {\n  throw new Error(\"AI output is not valid JSON after cleaning:\\n\" + cleaned);\n}\n\nreturn [{ json: parsed }];"
      },
